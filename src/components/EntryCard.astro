---
import Datetime from "./Datetime.astro";
import { toTransitionName } from "@/utils/toTransitionName";

type Props = {
  href: string;
  title: string;
  description?: string;
  meta?: string;
  externalUrl?: string;
  externalLabel?: string;
  compact?: boolean;
  pubDatetime: Date;
  modDatetime?: Date | null;
  timezone?: string;
  variant?: "h2" | "h3";
};

const {
  href,
  title,
  description,
  meta,
  externalUrl,
  externalLabel = "Project Link",
  compact = false,
  pubDatetime,
  modDatetime,
  timezone,
  variant: Heading = "h2",
} = Astro.props;

const externalAttrs = externalUrl?.startsWith("http")
  ? { target: "_blank", rel: "noreferrer" }
  : {};
---

<li class="my-6">
  {
    compact ? (
      <>
        <a
          href={href}
          class:list={[
            "text-accent inline-block text-xl font-semibold sm:text-2xl",
            "decoration-dashed underline-offset-4 hover:underline",
            "focus-visible:no-underline focus-visible:underline-offset-0",
          ]}
        >
          <Heading transition:name={toTransitionName(title)}>{title}</Heading>
        </a>
        <div class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1">
          <Datetime {pubDatetime} {modDatetime} {timezone} />
          {meta && <span class="text-muted-foreground text-sm">{meta}</span>}
        </div>
        {externalUrl && (
          <a
            href={externalUrl}
            class="text-accent mt-3 inline-block text-base font-medium decoration-dashed underline-offset-4 hover:underline"
            {...externalAttrs}
          >
            {externalLabel}
          </a>
        )}
        {description && (
          <p class="mt-4 max-w-prose leading-relaxed">{description}</p>
        )}
      </>
    ) : (
      <>
        <a
          href={href}
          class:list={[
            "text-accent inline-block text-lg font-medium",
            "decoration-dashed underline-offset-4 hover:underline",
            "focus-visible:no-underline focus-visible:underline-offset-0",
          ]}
        >
          <Heading transition:name={toTransitionName(title)}>{title}</Heading>
        </a>
        <div class="flex flex-wrap items-center gap-x-2">
          <Datetime {pubDatetime} {modDatetime} {timezone} />
          {meta && <span class="text-muted-foreground text-sm">{meta}</span>}
        </div>
        {description && <p>{description}</p>}
      </>
    )
  }
</li>
