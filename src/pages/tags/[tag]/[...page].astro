---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import Datetime from "@/components/Datetime.astro";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { getPostUrl } from "@/utils/getPostPaths";
import { postFilter } from "@/utils/postFilter";
import { slugifyAll } from "@/utils/slugify";
import { useTranslations } from "@/i18n";
import config from "@/config";

type TaggedItem = {
  kind: "post" | "project" | "archive";
  id: string;
  filePath?: string;
  title: string;
  description?: string;
  pubDatetime: Date;
  tags: string[];
};

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = (await getCollection("posts")).filter(postFilter);
  const projects = (await getCollection("projects")).filter(
    ({ data }) => !data.draft
  );
  const archives = (await getCollection("archives")).filter(
    ({ data }) => !data.draft
  );
  const tags = getUniqueTags([...posts, ...projects, ...archives]);

  const taggedItems: TaggedItem[] = [
    ...posts.map(entry => ({
      kind: "post" as const,
      id: entry.id,
      filePath: entry.filePath,
      title: entry.data.title,
      description: entry.data.description,
      pubDatetime: entry.data.pubDatetime,
      tags: entry.data.tags,
    })),
    ...projects.map(entry => ({
      kind: "project" as const,
      id: entry.id,
      title: entry.data.title,
      description: entry.data.description,
      pubDatetime: entry.data.pubDatetime,
      tags: entry.data.tags,
    })),
    ...archives.map(entry => ({
      kind: "archive" as const,
      id: entry.id,
      title: entry.data.title,
      description: entry.data.description,
      pubDatetime: entry.data.pubDatetime,
      tags: entry.data.tags,
    })),
  ].sort((a, b) => b.pubDatetime.getTime() - a.pubDatetime.getTime());

  return tags.flatMap(({ tag, tagName }) => {
    const items = taggedItems.filter(item =>
      slugifyAll(item.tags).includes(tag)
    );

    return paginate(items, {
      params: { tag },
      props: { tagName },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, tagName } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const kindLabels: Record<TaggedItem["kind"], string> = {
  post: t.nav.posts,
  project: t.nav.projects,
  archive: t.nav.archives,
};

const getItemUrl = (item: TaggedItem) => {
  if (item.kind === "post") return getPostUrl(item.id, item.filePath, locale);
  const basePath = item.kind === "project" ? "projects" : "archives";
  return (
    getRelativeLocaleUrl(locale, basePath) + "#" + encodeURIComponent(item.id)
  );
};
---

<Layout title={`${t.pages.tagTitle}: ${tagName} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main
    pageTitle={`${t.pages.tagTitle}: ${tagName}`}
    pageDesc={`${t.pages.tagDesc} "${tagName}"`}
  >
    <ul>
      {
        page.data.map((item: TaggedItem) => (
          <li class="my-6">
            <a
              href={getItemUrl(item)}
              class:list={[
                "text-accent inline-block text-lg font-medium",
                "decoration-dashed underline-offset-4 hover:underline",
                "focus-visible:no-underline focus-visible:underline-offset-0",
              ]}
            >
              <h2>{item.title}</h2>
            </a>
            <div class="flex flex-wrap items-center gap-x-2 text-sm opacity-75">
              <span>{kindLabels[item.kind]}</span>
              <Datetime pubDatetime={item.pubDatetime} />
            </div>
            {item.description && <p>{item.description}</p>}
          </li>
        ))
      }
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
