---
import { getCollection, getEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import EntryCard from "@/components/EntryCard.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getContentUrl } from "@/utils/getContentPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const home = await getEntry("pages", "home");
const homeData = home?.data;
const heroTitle = homeData?.heroTitle ?? config.site.title;
const intro = homeData?.intro?.length
  ? homeData.intro
  : [config.site.description];
const rssHref = import.meta.env.BASE_URL.replace(/\/?$/, "/") + "rss.xml";

const sortByDate = <T extends { data: { pubDatetime: Date; draft?: boolean } }>(
  items: T[]
) =>
  items
    .filter(({ data }) => !data.draft)
    .sort(
      (a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime()
    );

const projects = sortByDate(await getCollection("projects"));
const archives = sortByDate(await getCollection("archives"));
const featuredProjects = projects.filter(({ data }) => data.featured);

const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout
  title={config.site.title}
  description={homeData?.description ?? config.site.description}
>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        {heroTitle}
      </h1>
      <a
        target="_blank"
        href={rssHref}
        class="inline-block"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      {intro.map(item => <p class="mt-2">{item}</p>)}

      <div class="mt-5 flex flex-wrap gap-3">
        {
          homeData?.primaryLinkText && homeData?.primaryLinkUrl && (
            <LinkButton
              class="hover:text-accent underline decoration-dashed underline-offset-4"
              href={homeData.primaryLinkUrl}
            >
              {homeData.primaryLinkText}
            </LinkButton>
          )
        }
        {
          homeData?.secondaryLinkText && homeData?.secondaryLinkUrl && (
            <LinkButton
              class="hover:text-accent underline decoration-dashed underline-offset-4"
              href={homeData.secondaryLinkUrl}
            >
              {homeData.secondaryLinkText}
            </LinkButton>
          )
        }
      </div>

      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredProjects.length > 0 && (
        <section id="projects" class="border-border border-b pt-12 pb-6">
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-2xl font-semibold tracking-wide">
              {t.nav.projects}
            </h2>
            <LinkButton href={getRelativeLocaleUrl(locale, "projects")}>
              All Projects
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
          <ul>
            {featuredProjects.slice(0, 3).map(entry => (
              <EntryCard
                variant="h3"
                href={getContentUrl("projects", entry.id, locale)}
                title={entry.data.title}
                description={entry.data.description}
                pubDatetime={entry.data.pubDatetime}
              />
            ))}
          </ul>
        </section>
      )
    }

    {
      archives.length > 0 && (
        <section id="archives" class="border-border border-b pt-12 pb-6">
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-2xl font-semibold tracking-wide">
              {t.nav.archives}
            </h2>
            <LinkButton href={getRelativeLocaleUrl(locale, "archives")}>
              All Archives
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
          <ul>
            {archives.slice(0, 4).map(entry => (
              <EntryCard
                variant="h3"
                href={getContentUrl("archives", entry.id, locale)}
                title={entry.data.title}
                description={entry.data.description}
                pubDatetime={entry.data.pubDatetime}
              />
            ))}
          </ul>
        </section>
      )
    }

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
