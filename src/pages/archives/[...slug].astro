---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import { getContentSlug } from "@/utils/getContentPaths";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import BackButton from "@/pages/posts/[...slug]/_components/BackButton.astro";
import BackToTopButton from "@/pages/posts/[...slug]/_components/BackToTopButton.astro";
import config from "@/config";

export async function getStaticPaths() {
  const archives = (await getCollection("archives"))
    .filter(({ data }) => !data.draft)
    .sort(
      (a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime()
    );

  return archives.map(entry => ({
    params: { slug: getContentSlug(entry.id) },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"archives">;
};

const { entry } = Astro.props;
const { title, description, pubDatetime, tags } = entry.data;
const { Content } = await render(entry);

const imageSrc =
  typeof entry.data.image === "string"
    ? entry.data.image
    : entry.data.image?.src;
---

<PostLayout
  title={`${title} | ${config.site.title}`}
  description={description}
  pubDatetime={pubDatetime}
>
  <Header />

  <BackButton />

  <main
    id="main-content"
    class:list={["app-layout", { "mt-8": !config.features.showBackButton }]}
    data-pagefind-body
  >
    <h1
      style={{ viewTransitionName: toTransitionName(title) }}
      class="text-accent inline-block text-2xl font-bold sm:text-3xl"
    >
      {title}
    </h1>

    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} size="lg" />
    </div>

    {
      imageSrc && (
        <img
          src={imageSrc}
          alt=""
          class="mt-8 aspect-video w-full object-cover"
        />
      )
    }

    <article
      id="article"
      class:list={[
        "mt-8 w-full",
        "app-prose max-w-app",
        "prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)",
      ]}
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    <BackToTopButton />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>
  </main>
  <Footer />
</PostLayout>
