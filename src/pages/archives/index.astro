---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import EntryCard from "@/components/EntryCard.astro";
import { getContentUrl } from "@/utils/getContentPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (!config.features.showArchives && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const t = useTranslations(locale);

const entries = (await getCollection("archives"))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime());

const monthFormatter = new Intl.DateTimeFormat(locale, { month: "long" });
const years = Array.from(
  new Set(entries.map(entry => entry.data.pubDatetime.getFullYear()))
).sort((a, b) => b - a);
---

<Layout title={`${t.pages.archivesTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.archivesTitle} pageDesc={t.pages.archivesDesc}>
    {
      entries.length === 0 ? (
        <p>No archive entries yet.</p>
      ) : (
        years.map(year => {
          const yearItems = entries.filter(
            entry => entry.data.pubDatetime.getFullYear() === year
          );
          const months = Array.from(
            new Set(yearItems.map(entry => entry.data.pubDatetime.getMonth()))
          ).sort((a, b) => b - a);

          return (
            <div>
              <span class="text-2xl font-bold">{year}</span>
              <sup class="text-muted-foreground text-sm">
                {yearItems.length}
              </sup>
              {months.map(month => {
                const monthItems = yearItems.filter(
                  entry => entry.data.pubDatetime.getMonth() === month
                );

                return (
                  <div class="flex flex-col sm:flex-row">
                    <div class="mt-6 min-w-36 text-lg sm:my-6">
                      <span class="font-bold">
                        {monthFormatter.format(new Date(2000, month, 1))}
                      </span>
                      <sup class="text-muted-foreground text-xs">
                        {monthItems.length}
                      </sup>
                    </div>
                    <ul class="w-full">
                      {monthItems.map(entry => (
                        <EntryCard
                          href={getContentUrl("archives", entry.id, locale)}
                          title={entry.data.title}
                          description={entry.data.description}
                          pubDatetime={entry.data.pubDatetime}
                        />
                      ))}
                    </ul>
                  </div>
                );
              })}
            </div>
          );
        })
      )
    }
  </Main>

  <Footer />
</Layout>
